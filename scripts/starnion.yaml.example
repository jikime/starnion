# /etc/starnion/starnion.yaml  (or ~/.starnion/starnion.yaml)
# Starnion configuration — copy and fill in your values.
#
# Gateway and Agent both read this file.
# UI reads ui/.env (auto-generated by `starnion setup`).
#
# Permissions: chmod 600 starnion.yaml
# ─────────────────────────────────────────────────────────────────────────────

version: "1.0.0"

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
database:
  host: localhost          # or 127.0.0.1 / remote host
  port: 5432
  name: starnion
  user: starnion
  password: CHANGE_ME      # ← set a strong password
  ssl_mode: disable        # disable | require | verify-full

# ── Admin ─────────────────────────────────────────────────────────────────────
admin:
  email: admin@example.com

# ── MinIO (object storage) ────────────────────────────────────────────────────
minio:
  endpoint: localhost:9000          # host:port (derived from public_url if empty)
  access_key: minioadmin            # MinIO root user
  secret_key: CHANGE_ME            # ← set a strong password
  bucket: starnion-files
  public_url: http://localhost:9000 # URL the browser uses to access files
  use_ssl: false

# ── Gateway ───────────────────────────────────────────────────────────────────
gateway:
  host: 0.0.0.0            # bind address (0.0.0.0 = all interfaces)
  port: 8080
  url: http://localhost:8080  # public URL (used for OAuth redirect URIs)
  grpc_port: 50051
  agent_host: localhost    # hostname where the Python agent gRPC server runs

# ── UI ────────────────────────────────────────────────────────────────────────
ui:
  port: 3893

# ── Authentication ────────────────────────────────────────────────────────────
auth:
  # Generate with: openssl rand -hex 32
  jwt_secret: CHANGE_ME_32_BYTE_HEX_STRING
  auth_secret: CHANGE_ME_32_BYTE_HEX_STRING

# ── Google OAuth2 (optional) ──────────────────────────────────────────────────
# Register at: https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google Drive / Calendar integrations.
google:
  client_id: ""
  client_secret: ""
  redirect_uri: http://localhost:8080/auth/google/callback
  web_callback_uri: http://localhost:3893/integrations  # UI page after OAuth

# ── Gemini (server-level model, optional) ─────────────────────────────────────
gemini:
  model: gemini-2.5-pro   # fallback model when user has no Gemini key configured

# ── Embedding (server-wide — changing model requires re-indexing all vectors) ─
embedding:
  provider: openai                  # openai | gemini
  api_key: CHANGE_ME                # OpenAI or Gemini API key
  model: text-embedding-3-small     # must produce `dimensions`-length vectors
  dimensions: 768                   # must match pgvector column definition

# ── Logging ───────────────────────────────────────────────────────────────────
log:
  level: info      # debug | info | warn | error
  format: json     # json (for journald) | console (human-readable)

# ── CORS ──────────────────────────────────────────────────────────────────────
cors:
  allowed_origins:
    - http://localhost:3893
    # Add your production UI URL:
    # - https://your-domain.com
  allowed_methods:
    - GET
    - POST
    - PUT
    - DELETE
    - OPTIONS
    - PATCH
  allowed_headers:
    - Authorization
    - Content-Type
