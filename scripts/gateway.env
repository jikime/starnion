# /etc/starnion/gateway.env
# Systemd EnvironmentFile for starnion-gateway.service
#
# HOW THIS WORKS
# ──────────────
# The gateway reads its main configuration from:
#   ${HOME}/.starnion/starnion.yaml
#
# This file sets the *process environment* for the systemd service unit.
# It does NOT replace starnion.yaml — use this file to:
#   1. Point HOME at the correct user directory
#   2. Tune Go runtime parameters (GOMAXPROCS, GOGC)
#   3. Set any overrides that starnion.yaml cannot express
#
# After editing, reload with:
#   sudo systemctl daemon-reload && sudo systemctl restart starnion-gateway
#
# ── User home (required) ──────────────────────────────────────────────────────
# systemd does not set HOME automatically for Type=simple services.
# Set this to the home directory of the User= specified in the .service file.
# starnion.yaml must exist at ${HOME}/.starnion/starnion.yaml
HOME=/home/starnion

# ── Go runtime tuning ─────────────────────────────────────────────────────────
# Number of OS threads for Go to use. Defaults to number of CPU cores.
# Set to the number of vCPUs on your server for best performance.
# Example: 2-core server → GOMAXPROCS=2
GOMAXPROCS=2

# Garbage collector target percentage (default 100).
# Lower value (e.g. 50) runs GC more frequently, reducing peak memory.
# Higher value (e.g. 200) reduces CPU overhead at the cost of more RAM.
GOGC=100

# ── Optional: override config file path ───────────────────────────────────────
# Uncomment to use a non-default config location (e.g. when running as root
# or using a shared config directory). The gateway checks this var first.
# STARNION_CONFIG=/etc/starnion/starnion.yaml

# ── TZ (optional) ─────────────────────────────────────────────────────────────
# Set the process timezone. Affects log timestamps when format=console.
# Leave unset to inherit the system timezone.
# TZ=Asia/Seoul
