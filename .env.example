# ============================
# Jiki Environment Variables
# ============================
# Copy this file to .env and fill in your values.

# --- Database ---
DATABASE_URL=postgresql://postgres:admin@localhost:5432/jiki?sslmode=disable

# --- Google Gemini (AI Agent) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- JWT (Gateway WebSocket auth + account linking) ---
JWT_SECRET=your-jwt-secret-min-32-chars

# --- gRPC ---
GRPC_PORT=50051
GRPC_AGENT_HOST=localhost:50051

# --- Google OAuth2 (Workspace integration: Calendar, Docs, Drive, Gmail, Tasks) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# --- Google Cloud (TTS) ---
# Path to service account JSON or leave empty to use ADC.
GOOGLE_CLOUD_CREDENTIALS=

# --- MinIO (File Storage) ---
MINIO_ACCESS_KEY=gilgeori
MINIO_SECRET_KEY=gilgeori3893
MINIO_BUCKET=jiki-files
# Internal endpoint (gateway → MinIO): use container name in docker, localhost in dev
MINIO_ENDPOINT=gilgeori-minio:9000
# Browser-accessible URL for displaying files in web UI
MINIO_PUBLIC_URL=http://localhost:9000
