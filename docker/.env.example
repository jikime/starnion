# StarNion Docker Environment
# Copy to .env and fill in values, or run: starnion docker setup
#
# Secrets (required — do NOT use defaults in production)
POSTGRES_PASSWORD=change-me-in-production
MINIO_SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-min-32-chars-in-production
AUTH_SECRET=change-me-min-32-chars-in-production

# PostgreSQL
POSTGRES_DB=starnion
POSTGRES_USER=starnion
POSTGRES_PORT=5432

# MinIO
MINIO_ACCESS_KEY=starnion
MINIO_BUCKET=starnion-files
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_URL=http://localhost:9000

# Gateway
GATEWAY_PORT=8080
GATEWAY_PUBLIC_URL=http://localhost:8080
GRPC_PORT=50051

# UI
UI_PORT=3000
NEXTAUTH_URL=http://localhost:3000

# Browser automation (optional — default: true / headless mode)
# Set to false for local development to show a visible browser window
# BROWSER_HEADLESS=false

# Embedding (set by starnion setup — do not edit manually)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=768
