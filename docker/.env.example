# StarNion Docker Environment
# Copy to .env and fill in the required values.
# Generate secrets: openssl rand -hex 32

# ── Required secrets ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me
MINIO_SECRET_KEY=change-me
JWT_SECRET=change-me-32-chars-minimum
ENCRYPTION_KEY=change-me-32-chars-minimum
AUTH_SECRET=change-me-32-chars-minimum

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=starnion
POSTGRES_USER=starnion
POSTGRES_PORT=5432

# ── MinIO (S3-compatible storage) ─────────────────────────────────────────────
MINIO_ACCESS_KEY=starnion
MINIO_BUCKET=starnion-files
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_URL=http://localhost:9000

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_PUBLIC_URL=http://localhost:8080
GRPC_PORT=50051
ALLOWED_ORIGINS=http://localhost:3893
INTERNAL_LOG_SECRET=

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
WEB_PORT=3893
NEXTAUTH_URL=http://localhost:3893

# ── Agent ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
TZ=Asia/Seoul
BROWSER_HEADLESS=true
