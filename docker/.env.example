# StarPion Docker Environment
# Copy to .env and fill in values, or run: starpion docker setup
#
# Secrets (required — do NOT use defaults in production)
POSTGRES_PASSWORD=change-me-in-production
MINIO_SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-min-32-chars-in-production
AUTH_SECRET=change-me-min-32-chars-in-production

# PostgreSQL
POSTGRES_DB=starpion
POSTGRES_USER=starpion
POSTGRES_PORT=5432

# MinIO
MINIO_ACCESS_KEY=starpion
MINIO_BUCKET=starpion-files
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_URL=http://localhost:9000

# Gateway
GATEWAY_PORT=8080
GATEWAY_PUBLIC_URL=http://localhost:8080
GRPC_PORT=50051

# UI
UI_PORT=3000
NEXTAUTH_URL=http://localhost:3000
