# ── Dependencies ──────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps

WORKDIR /app
RUN corepack enable
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# ── Builder ───────────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app
RUN corepack enable
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN pnpm build

# ── Production deps ───────────────────────────────────────────────────────────
FROM node:22-alpine AS prod-deps

WORKDIR /app
RUN corepack enable
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile --prod --ignore-scripts

# ── Runner ────────────────────────────────────────────────────────────────────
FROM node:22-alpine AS runner

WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 starnion

COPY --from=builder --chown=starnion:nodejs /app/dist ./dist
COPY --from=prod-deps --chown=starnion:nodejs /app/node_modules ./node_modules
COPY --chown=starnion:nodejs package.json ./
# Include skills so the gateway can read SKILL.md files via SKILLS_DIR
COPY --chown=starnion:nodejs skills/ ./skills/

USER starnion
EXPOSE 50051

CMD ["node", "dist/server/index.js"]
