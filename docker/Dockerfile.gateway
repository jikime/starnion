FROM golang:1.23-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /gateway ./cmd/gateway

FROM alpine:3.20
RUN apk --no-cache add ca-certificates
COPY --from=builder /gateway /gateway
COPY config.yaml /config.yaml

EXPOSE 8080 50051
CMD ["/gateway"]
